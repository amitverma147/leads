{
  "version": 2,
  "buildCommand": "npx prisma generate --schema=src/database/prisma/schema.prisma && npm run build",
  "builds": [
    {
      "src": "src/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/**", "src/database/prisma/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/app.ts"
    }
  ]
}
